<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALl Tiltle</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quora Posts</h1>

     <% for (post of posts){ %>
             <div class="post">
                <h3 class="user">@<%=post.username %></h3>
                <h4 class="stuff"><%=post.content %></h4>
                <a href="/posts/<%=post.id%>">
                   <button>
                     See in detial
                   </button>
                </a> 
                <a href="/posts/<%=post.id%>/edit">
                  <button>
                     Edit post!
                  </button>
                </a>
                <form method="post" action="/posts/<%=post.id%>?_method=DELETE">
                  <button>
                     Delete Post
                  </button>
                </form>
             </div>
        <% } %> 
     <br>                              
     <a href="/posts/new">
     <button>
        Create New Posts!
     </button>   
     </a>
</body>
</html>
